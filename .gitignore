# Fichiers à ignorer par Git dans le projet principal

# Dépendances
/node_modules

# Next.js
/.next/
/out/

# Production
/build

# Fichiers d'environnement locaux (secrets)
.env*.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Scripts et fichiers de travail jetables
/scratch/

# Environnements virtuels Python (ex: .claude/skills/seo/.venv)
.venv/
__pycache__/
*.pyc

# Logs de debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Couverture de tests
/coverage

# Fichiers temporaires ou IDE
.DS_Store
Thumbs.db
*.pem
